<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  AquaMap — Design System / Paleta de Cores                -->
    <!--  Temática: Água, Monitoramento Ambiental, Institucional   -->
    <!-- ═══════════════════════════════════════════════════════════ -->

    <!-- Cores Primárias (Água/Institucional) -->
    <Color x:Key="AquaPrimary">#0891B2</Color>
    <Color x:Key="AquaPrimaryDark">#155E75</Color>
    <Color x:Key="AquaPrimaryDeep">#0E4F63</Color>
    <Color x:Key="AquaAccent">#06B6D4</Color>
    <Color x:Key="AquaLight">#CFFAFE</Color>
    <Color x:Key="AquaSoft">#E0F7FA</Color>

    <!-- Cores de Status (Qualidade da Água — Portaria 888) -->
    <Color x:Key="StatusSafe">#10B981</Color>
    <Color x:Key="StatusSafeLight">#D1FAE5</Color>
    <Color x:Key="StatusWarning">#F59E0B</Color>
    <Color x:Key="StatusWarningLight">#FEF3C7</Color>
    <Color x:Key="StatusDanger">#EF4444</Color>
    <Color x:Key="StatusDangerLight">#FEE2E2</Color>

    <!-- Superfícies -->
    <Color x:Key="SurfaceLight">#F0FDFA</Color>
    <Color x:Key="SurfaceDark">#0F172A</Color>
    <Color x:Key="CardLight">#FFFFFF</Color>
    <Color x:Key="CardDark">#1E293B</Color>
    <Color x:Key="CardBorderLight">#E2E8F0</Color>
    <Color x:Key="CardBorderDark">#334155</Color>

    <!-- Texto -->
    <Color x:Key="TextPrimary">#0F172A</Color>
    <Color x:Key="TextSecondary">#64748B</Color>
    <Color x:Key="TextMuted">#94A3B8</Color>
    <Color x:Key="TextOnDark">#F8FAFC</Color>

    <!-- Compatibilidade com estilos existentes -->
    <Color x:Key="Primary">#0891B2</Color>
    <Color x:Key="PrimaryDark">#67E8F9</Color>
    <Color x:Key="PrimaryDarkText">#0E4F63</Color>
    <Color x:Key="Secondary">#CFFAFE</Color>
    <Color x:Key="SecondaryDarkText">#22D3EE</Color>
    <Color x:Key="Tertiary">#155E75</Color>

    <Color x:Key="White">White</Color>
    <Color x:Key="Black">#0F172A</Color>
    <Color x:Key="Magenta">#0891B2</Color>
    <Color x:Key="MidnightBlue">#0E4F63</Color>
    <Color x:Key="OffBlack">#0F172A</Color>

    <Color x:Key="Gray100">#F1F5F9</Color>
    <Color x:Key="Gray200">#E2E8F0</Color>
    <Color x:Key="Gray300">#CBD5E1</Color>
    <Color x:Key="Gray400">#94A3B8</Color>
    <Color x:Key="Gray500">#64748B</Color>
    <Color x:Key="Gray600">#475569</Color>
    <Color x:Key="Gray900">#1E293B</Color>
    <Color x:Key="Gray950">#0F172A</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}"/>
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource Tertiary}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>

    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}"/>
</ResourceDictionary>