<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:AquaMap.ViewModels"
             xmlns:models="clr-namespace:AquaMap.Domain.Entities;assembly=AquaMap.Domain"
             x:Class="AquaMap.MainPage"
             x:DataType="vm:MainViewModel"
             Title="Reservatórios"
             BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}">

    <Grid RowDefinitions="Auto, *">

        <!-- Header -->
        <Border Grid.Row="0" StrokeShape="RoundRectangle 0,0,20,20" Stroke="Transparent" Padding="24,20,24,18">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#155E75" Offset="0.0" />
                    <GradientStop Color="#0891B2" Offset="1.0" />
                </LinearGradientBrush>
            </Border.Background>
            <Border.Shadow>
                <Shadow Brush="#155E75" Offset="0,4" Radius="16" Opacity="0.3" />
            </Border.Shadow>
            <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="14">
                <Image Source="aquamap_logo.png" HeightRequest="44" WidthRequest="44" VerticalOptions="Center" />
                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                    <Label Text="AquaMap" FontSize="22" FontAttributes="Bold" TextColor="White" />
                    <Label Text="Pontos de monitoramento" FontSize="12" TextColor="#A5F3FC" Opacity="0.85" />
                </VerticalStackLayout>
                <Button Grid.Column="2" Text="+" Command="{Binding AddReservoirCommand}" FontSize="22" FontAttributes="Bold" TextColor="White" BackgroundColor="#06B6D4" CornerRadius="12" WidthRequest="44" HeightRequest="44" Padding="0" VerticalOptions="Center" />
            </Grid>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="1">
            <!-- Loading -->
            <VerticalStackLayout IsVisible="{Binding IsBusy}" VerticalOptions="Center" HorizontalOptions="Center" Spacing="12">
                <ActivityIndicator IsRunning="{Binding IsBusy}" Color="{StaticResource AquaPrimary}" HeightRequest="40" WidthRequest="40" />
                <Label Text="Carregando..." FontSize="14" TextColor="{StaticResource TextSecondary}" HorizontalOptions="Center" />
            </VerticalStackLayout>

            <!-- Empty State -->
            <VerticalStackLayout IsVisible="{Binding IsEmpty}" VerticalOptions="Center" HorizontalOptions="Center" Spacing="10" Padding="40">
                <Label Text="💧" FontSize="48" HorizontalOptions="Center" />
                <Label Text="Nenhum reservatório" FontSize="17" FontAttributes="Bold" TextColor="{StaticResource TextSecondary}" HorizontalOptions="Center" />
                <Label Text="Verifique a conexão com o servidor." FontSize="13" TextColor="{StaticResource TextMuted}" HorizontalTextAlignment="Center" HorizontalOptions="Center" />
            </VerticalStackLayout>

            <!-- List -->
            <RefreshView Command="{Binding LoadPointsCommand}" IsRefreshing="{Binding IsRefreshing}" RefreshColor="{StaticResource AquaPrimary}" IsVisible="{Binding HasData}">
                <CollectionView ItemsSource="{Binding Points}" Margin="16,12,16,8">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Reservoir">
                            <Border Margin="0,6" Padding="16,14" StrokeShape="RoundRectangle 16" Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}" BackgroundColor="{AppThemeBinding Light=White, Dark=#1E293B}">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=OpenDetailCommand}" CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                                <Border.Shadow>
                                    <Shadow Brush="#000000" Offset="0,2" Radius="8" Opacity="0.06" />
                                </Border.Shadow>
                                <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="14">
                                    <!-- Status Icon -->
                                    <Border Grid.Column="0" WidthRequest="40" HeightRequest="40" StrokeShape="RoundRectangle 12" Stroke="Transparent" VerticalOptions="Center" BackgroundColor="#F1F5F9">
                                        <Border.Triggers>
                                            <DataTrigger TargetType="Border" Binding="{Binding StatusColor}" Value="Green"><Setter Property="BackgroundColor" Value="#D1FAE5" /></DataTrigger>
                                            <DataTrigger TargetType="Border" Binding="{Binding StatusColor}" Value="Red"><Setter Property="BackgroundColor" Value="#FEE2E2" /></DataTrigger>
                                        </Border.Triggers>
                                        <Label HorizontalOptions="Center" VerticalOptions="Center" FontSize="18" Text="—" TextColor="#94A3B8">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label" Binding="{Binding StatusColor}" Value="Green"><Setter Property="Text" Value="✓" /><Setter Property="TextColor" Value="#10B981" /></DataTrigger>
                                                <DataTrigger TargetType="Label" Binding="{Binding StatusColor}" Value="Red"><Setter Property="Text" Value="✕" /><Setter Property="TextColor" Value="#EF4444" /></DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                    </Border>
                                    <!-- Info -->
                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="3">
                                        <Label Text="{Binding Name}" FontSize="16" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#0F172A, Dark=White}" LineBreakMode="TailTruncation" />
                                        <Label FontSize="12" TextColor="{StaticResource TextMuted}" Text="Aguardando análise">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label" Binding="{Binding StatusColor}" Value="Green"><Setter Property="Text" Value="Água potável — Portaria 888" /></DataTrigger>
                                                <DataTrigger TargetType="Label" Binding="{Binding StatusColor}" Value="Red"><Setter Property="Text" Value="Parâmetros fora do padrão" /></DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                    </VerticalStackLayout>
                                    <!-- Badge -->
                                    <Border Grid.Column="2" StrokeShape="RoundRectangle 8" Stroke="Transparent" Padding="10,5" VerticalOptions="Center" BackgroundColor="#F1F5F9">
                                        <Border.Triggers>
                                            <DataTrigger TargetType="Border" Binding="{Binding StatusColor}" Value="Green"><Setter Property="BackgroundColor" Value="#D1FAE5" /></DataTrigger>
                                            <DataTrigger TargetType="Border" Binding="{Binding StatusColor}" Value="Red"><Setter Property="BackgroundColor" Value="#FEE2E2" /></DataTrigger>
                                        </Border.Triggers>
                                        <Label FontSize="11" FontAttributes="Bold" Text="N/A" TextColor="#94A3B8">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label" Binding="{Binding StatusColor}" Value="Green"><Setter Property="Text" Value="Potável" /><Setter Property="TextColor" Value="#10B981" /></DataTrigger>
                                                <DataTrigger TargetType="Label" Binding="{Binding StatusColor}" Value="Red"><Setter Property="Text" Value="Alerta" /><Setter Property="TextColor" Value="#EF4444" /></DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </RefreshView>
        </Grid>
    </Grid>
</ContentPage>