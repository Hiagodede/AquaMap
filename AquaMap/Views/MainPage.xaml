<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:AquaMap.ViewModels"
             xmlns:models="clr-namespace:AquaMap.Domain.Entities;assembly=AquaMap.Domain"
             x:Class="AquaMap.MainPage"
             x:DataType="vm:MainViewModel"
             Title="Pontos de Coleta">

    <Grid RowDefinitions="Auto, *">

        <Label Text="Monitoramento AquaMap" 
               FontSize="24" 
               FontAttributes="Bold"
               HorizontalOptions="Center" 
               Margin="0,20,0,10"/>

        <CollectionView Grid.Row="1" 
                        ItemsSource="{Binding Points}"
                        Margin="20">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:CollectionPoint">
                    <Border Margin="0,5" 
                            Padding="10" 
                            Stroke="Gray" 
                            StrokeShape="RoundRectangle 10">

                        <VerticalStackLayout>
                            <Label Text="{Binding Name}" 
                                   FontSize="18" 
                                   FontAttributes="Bold" />

                            <Label Text="{Binding Description}" 
                                   TextColor="Gray" />

                            <Label Text="{Binding Latitude, StringFormat='Lat: {0:F4}'}" 
                                   FontSize="12" />
                        </VerticalStackLayout>

                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>

</ContentPage>