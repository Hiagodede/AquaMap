<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:AquaMap.ViewModels"
             x:Class="AquaMap.Views.ReservoirFormPage"
             x:DataType="vm:ReservoirFormViewModel"
             Title="{Binding PageTitle}"
             BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}">

    <ScrollView>
        <VerticalStackLayout Spacing="16" Padding="20,16">

            <!-- Header Card -->
            <Border StrokeShape="RoundRectangle 16" Stroke="Transparent" Padding="20,16">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#155E75" Offset="0.0" />
                        <GradientStop Color="#0891B2" Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>
                <VerticalStackLayout Spacing="4">
                    <Label Text="{Binding PageTitle}" FontSize="20" FontAttributes="Bold" TextColor="White" />
                    <Label Text="Preencha o nome, localização e bairros atendidos" FontSize="13" TextColor="#A5F3FC" Opacity="0.85" />
                </VerticalStackLayout>
            </Border>

            <!-- Nome -->
            <Border StrokeShape="RoundRectangle 16"
                    Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#1E293B}"
                    Padding="18,16">
                <Border.Shadow><Shadow Brush="#000" Offset="0,2" Radius="8" Opacity="0.05" /></Border.Shadow>
                <VerticalStackLayout Spacing="8">
                    <Label Text="📌 Nome do Reservatório" FontSize="14" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#0E4F63, Dark=#67E8F9}" />
                    <Border StrokeShape="RoundRectangle 10"
                            Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}"
                            BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#0F172A}"
                            Padding="14,2" HeightRequest="48">
                        <Entry Placeholder="Ex: Reservatório Central SAAE"
                               Text="{Binding ReservoirName}"
                               MaxLength="100" FontSize="15" />
                    </Border>
                </VerticalStackLayout>
            </Border>

            <!-- ═══════════════ LOCALIZAÇÃO (nova UX) ═══════════════ -->
            <Border StrokeShape="RoundRectangle 16"
                    Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#1E293B}"
                    Padding="18,16">
                <Border.Shadow><Shadow Brush="#000" Offset="0,2" Radius="8" Opacity="0.05" /></Border.Shadow>
                <VerticalStackLayout Spacing="14">

                    <Label Text="📍 Localização do Ponto de Coleta" FontSize="14" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#0E4F63, Dark=#67E8F9}" />

                    <!-- Feedback de localização capturada -->
                    <Border IsVisible="{Binding LocationCaptured}"
                            StrokeShape="RoundRectangle 10" Stroke="Transparent"
                            BackgroundColor="#D1FAE5" Padding="14,10">
                        <Grid ColumnDefinitions="*, Auto">
                            <Label Grid.Column="0" Text="{Binding LocationDisplay}"
                                   FontSize="13" FontAttributes="Bold" TextColor="#065F46"
                                   VerticalOptions="Center" />
                            <Label Grid.Column="1" Text="✓" FontSize="16" TextColor="#10B981"
                                   VerticalOptions="Center" />
                        </Grid>
                    </Border>

                    <!-- BOTÃO PRIMÁRIO: Usar GPS -->
                    <Button Text="📍 Usar Minha Localização Atual"
                            Command="{Binding CaptureLocationCommand}"
                            IsEnabled="{Binding IsNotBusy}"
                            FontSize="15" FontAttributes="Bold"
                            HeightRequest="52" CornerRadius="12"
                            TextColor="White">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#0891B2" Offset="0.0" />
                                <GradientStop Color="#06B6D4" Offset="1.0" />
                            </LinearGradientBrush>
                        </Button.Background>
                        <Button.Shadow><Shadow Brush="#0891B2" Offset="0,4" Radius="12" Opacity="0.3" /></Button.Shadow>
                        <Button.Triggers>
                            <DataTrigger TargetType="Button" Binding="{Binding IsCapturingGps}" Value="True">
                                <Setter Property="Text" Value="🔄 Buscando GPS..." />
                                <Setter Property="Opacity" Value="0.7" />
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>

                    <!-- BOTÃO SECUNDÁRIO: Marcar no mapa -->
                    <Button Text="{Binding MapPickerButtonText}"
                            Command="{Binding ToggleMapPickerCommand}"
                            IsEnabled="{Binding IsNotBusy}"
                            FontSize="13"
                            HeightRequest="40" CornerRadius="10"
                            TextColor="{AppThemeBinding Light=#0369A1, Dark=#38BDF8}"
                            BackgroundColor="{AppThemeBinding Light=#E0F2FE, Dark=#0C4A6E}" />

                    <!-- Mapa Leaflet Picker -->
                    <Border IsVisible="{Binding IsMapPickerVisible}"
                            StrokeShape="RoundRectangle 12"
                            Stroke="{AppThemeBinding Light=#BAE6FD, Dark=#0369A1}"
                            HeightRequest="300"
                            Padding="0">
                        <WebView x:Name="MapPickerWebView"
                                 HorizontalOptions="Fill"
                                 VerticalOptions="Fill" />
                    </Border>

                    <!-- LINK TERCIÁRIO: Coordenadas manuais -->
                    <Button Text="{Binding ManualInputButtonText}"
                            Command="{Binding ToggleManualInputCommand}"
                            FontSize="11"
                            HeightRequest="32" CornerRadius="8"
                            TextColor="{StaticResource TextMuted}"
                            BackgroundColor="Transparent" />

                    <!-- Entradas manuais (fallback) -->
                    <VerticalStackLayout IsVisible="{Binding IsManualInputVisible}" Spacing="10">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Latitude" FontSize="12" TextColor="{StaticResource TextSecondary}" />
                            <Border StrokeShape="RoundRectangle 10"
                                    Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}"
                                    BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#0F172A}"
                                    Padding="14,2" HeightRequest="44">
                                <Entry Placeholder="Ex: -20.763600"
                                       Text="{Binding ReservoirLatitude}"
                                       Keyboard="Numeric" MaxLength="12" FontSize="14" />
                            </Border>
                        </VerticalStackLayout>
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Longitude" FontSize="12" TextColor="{StaticResource TextSecondary}" />
                            <Border StrokeShape="RoundRectangle 10"
                                    Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}"
                                    BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#0F172A}"
                                    Padding="14,2" HeightRequest="44">
                                <Entry Placeholder="Ex: -41.533300"
                                       Text="{Binding ReservoirLongitude}"
                                       Keyboard="Numeric" MaxLength="12" FontSize="14" />
                            </Border>
                        </VerticalStackLayout>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Border>

            <!-- ═══════════════ BAIRROS ATENDIDOS ═══════════════ -->
            <Border StrokeShape="RoundRectangle 16"
                    Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#1E293B}"
                    Padding="18,16">
                <Border.Shadow><Shadow Brush="#000" Offset="0,2" Radius="8" Opacity="0.05" /></Border.Shadow>
                <VerticalStackLayout Spacing="12">

                    <!-- Cabeçalho com contador -->
                    <Grid ColumnDefinitions="*, Auto">
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label Text="🏘️ Bairros Atendidos" FontSize="14" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#0E4F63, Dark=#67E8F9}" />
                            <Label Text="Selecione todos os pontos de coleta cobertos" FontSize="11"
                                   TextColor="{StaticResource TextMuted}" />
                        </VerticalStackLayout>
                        <Border Grid.Column="1"
                                StrokeShape="RoundRectangle 10" Stroke="Transparent"
                                BackgroundColor="#DBEAFE" Padding="10,5" VerticalOptions="Center">
                            <Label TextColor="#1D4ED8" FontAttributes="Bold" FontSize="12">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="{Binding SelectedNeighborhoodsCount}" />
                                        <Span Text="/18" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>
                        </Border>
                    </Grid>

                    <!-- Grid de checkboxes (2 colunas) -->
                    <CollectionView ItemsSource="{Binding Neighborhoods}"
                                    SelectionMode="None">
                        <CollectionView.ItemsLayout>
                            <GridItemsLayout Orientation="Vertical" Span="2" HorizontalItemSpacing="8" VerticalItemSpacing="0" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="vm:NeighborhoodCheckItem">
                                <Border Margin="0,3"
                                        StrokeShape="RoundRectangle 10"
                                        Padding="14,10">
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                            <Setter Property="BackgroundColor" Value="#EFF6FF" />
                                            <Setter Property="Stroke" Value="#93C5FD" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="False">
                                            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#F8FAFC, Dark=#0F172A}" />
                                            <Setter Property="Stroke" Value="{AppThemeBinding Light=#E2E8F0, Dark=#334155}" />
                                        </DataTrigger>
                                    </Border.Triggers>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding ToggleCommand}" />
                                    </Border.GestureRecognizers>
                                    <Grid ColumnDefinitions="Auto, *" ColumnSpacing="12">
                                        <!-- Checkbox visual -->
                                        <Border Grid.Column="0"
                                                WidthRequest="24" HeightRequest="24"
                                                StrokeShape="RoundRectangle 6"
                                                VerticalOptions="Center">
                                            <Border.Triggers>
                                                <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="BackgroundColor" Value="#2563EB" />
                                                    <Setter Property="Stroke" Value="#2563EB" />
                                                </DataTrigger>
                                                <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="False">
                                                    <Setter Property="BackgroundColor" Value="Transparent" />
                                                    <Setter Property="Stroke" Value="#CBD5E1" />
                                                </DataTrigger>
                                            </Border.Triggers>
                                            <Label Text="✓" FontSize="13" FontAttributes="Bold"
                                                   HorizontalOptions="Center" VerticalOptions="Center">
                                                <Label.Triggers>
                                                    <DataTrigger TargetType="Label" Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="TextColor" Value="White" />
                                                    </DataTrigger>
                                                    <DataTrigger TargetType="Label" Binding="{Binding IsSelected}" Value="False">
                                                        <Setter Property="TextColor" Value="Transparent" />
                                                    </DataTrigger>
                                                </Label.Triggers>
                                            </Label>
                                        </Border>
                                        <!-- Nome do bairro -->
                                        <Label Grid.Column="1" Text="{Binding Name}"
                                               FontSize="13" VerticalOptions="Center">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label" Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="TextColor" Value="#1E40AF" />
                                                    <Setter Property="FontAttributes" Value="Bold" />
                                                </DataTrigger>
                                                <DataTrigger TargetType="Label" Binding="{Binding IsSelected}" Value="False">
                                                    <Setter Property="TextColor" Value="{AppThemeBinding Light=#334155, Dark=#94A3B8}" />
                                                    <Setter Property="FontAttributes" Value="None" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>
            </Border>

            <!-- Botão Salvar -->
            <Button Text="Salvar Reservatório" Command="{Binding SaveCommand}"
                    IsEnabled="{Binding IsNotBusy}"
                    FontSize="16" FontAttributes="Bold"
                    HeightRequest="52" CornerRadius="14"
                    TextColor="White" Margin="0,4,0,0">
                <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#0891B2" Offset="0.0" />
                        <GradientStop Color="#06B6D4" Offset="1.0" />
                    </LinearGradientBrush>
                </Button.Background>
                <Button.Shadow><Shadow Brush="#0891B2" Offset="0,4" Radius="12" Opacity="0.35" /></Button.Shadow>
                <Button.Triggers>
                    <DataTrigger TargetType="Button" Binding="{Binding IsBusy}" Value="True">
                        <Setter Property="Text" Value="Salvando..." />
                        <Setter Property="Opacity" Value="0.6" />
                    </DataTrigger>
                </Button.Triggers>
            </Button>

            <!-- Botão Excluir (apenas edição) -->
            <Button Text="Excluir Reservatório" Command="{Binding DeleteCommand}"
                    IsVisible="{Binding IsEditing}" IsEnabled="{Binding IsNotBusy}"
                    FontSize="14" HeightRequest="46" CornerRadius="14"
                    TextColor="#EF4444" BackgroundColor="#FEE2E2"
                    BorderColor="#FECACA" BorderWidth="1" />

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                               Color="{StaticResource AquaPrimary}" HorizontalOptions="Center" />

            <!-- Mensagem de status -->
            <Border IsVisible="{Binding HasStatus}" StrokeShape="RoundRectangle 12"
                    Stroke="Transparent" Padding="16,12" Margin="0,0,0,10">
                <Border.Triggers>
                    <DataTrigger TargetType="Border" Binding="{Binding IsSuccess}" Value="True"><Setter Property="BackgroundColor" Value="#D1FAE5" /></DataTrigger>
                    <DataTrigger TargetType="Border" Binding="{Binding IsSuccess}" Value="False"><Setter Property="BackgroundColor" Value="#FEE2E2" /></DataTrigger>
                </Border.Triggers>
                <Label Text="{Binding StatusMessage}" FontSize="13"
                       HorizontalTextAlignment="Center" HorizontalOptions="Center">
                    <Label.Triggers>
                        <DataTrigger TargetType="Label" Binding="{Binding IsSuccess}" Value="True"><Setter Property="TextColor" Value="#10B981" /></DataTrigger>
                        <DataTrigger TargetType="Label" Binding="{Binding IsSuccess}" Value="False"><Setter Property="TextColor" Value="#EF4444" /></DataTrigger>
                    </Label.Triggers>
                </Label>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
