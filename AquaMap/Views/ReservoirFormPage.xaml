<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:AquaMap.ViewModels"
             x:Class="AquaMap.Views.ReservoirFormPage"
             x:DataType="vm:ReservoirFormViewModel"
             Title="{Binding PageTitle}"
             BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}">

    <ScrollView>
        <VerticalStackLayout Spacing="16" Padding="20,16">

            <!-- Header Card -->
            <Border StrokeShape="RoundRectangle 16" Stroke="Transparent" Padding="20,16">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#155E75" Offset="0.0" />
                        <GradientStop Color="#0891B2" Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>
                <VerticalStackLayout Spacing="4">
                    <Label Text="{Binding PageTitle}" FontSize="20" FontAttributes="Bold" TextColor="White" />
                    <Label Text="Defina o nome e as coordenadas do ponto de coleta" FontSize="13" TextColor="#A5F3FC" Opacity="0.85" />
                </VerticalStackLayout>
            </Border>

            <!-- Nome -->
            <Border StrokeShape="RoundRectangle 16" Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}" BackgroundColor="{AppThemeBinding Light=White, Dark=#1E293B}" Padding="18,16">
                <Border.Shadow><Shadow Brush="#000" Offset="0,2" Radius="8" Opacity="0.05" /></Border.Shadow>
                <VerticalStackLayout Spacing="8">
                    <Label Text="📍 Nome do Reservatório" FontSize="14" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#0E4F63, Dark=#67E8F9}" />
                    <Border StrokeShape="RoundRectangle 10" Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}" BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#0F172A}" Padding="14,2" HeightRequest="48">
                        <Entry Placeholder="Ex: Reservatório Central SAAE" Text="{Binding ReservoirName}" MaxLength="100" FontSize="15" />
                    </Border>
                </VerticalStackLayout>
            </Border>

            <!-- Coordenadas -->
            <Border StrokeShape="RoundRectangle 16" Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}" BackgroundColor="{AppThemeBinding Light=White, Dark=#1E293B}" Padding="18,16">
                <Border.Shadow><Shadow Brush="#000" Offset="0,2" Radius="8" Opacity="0.05" /></Border.Shadow>
                <VerticalStackLayout Spacing="14">
                    <Label Text="🌐 Coordenadas Geográficas" FontSize="14" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#0E4F63, Dark=#67E8F9}" />

                    <VerticalStackLayout Spacing="4">
                        <Label Text="Latitude" FontSize="13" TextColor="{StaticResource TextSecondary}" />
                        <Border StrokeShape="RoundRectangle 10" Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}" BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#0F172A}" Padding="14,2" HeightRequest="48">
                            <Entry Placeholder="Ex: -20.7636" Text="{Binding ReservoirLatitude}" Keyboard="Numeric" MaxLength="12" FontSize="15" />
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="4">
                        <Label Text="Longitude" FontSize="13" TextColor="{StaticResource TextSecondary}" />
                        <Border StrokeShape="RoundRectangle 10" Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}" BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#0F172A}" Padding="14,2" HeightRequest="48">
                            <Entry Placeholder="Ex: -41.5333" Text="{Binding ReservoirLongitude}" Keyboard="Numeric" MaxLength="12" FontSize="15" />
                        </Border>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Save Button -->
            <Button Text="Salvar" Command="{Binding SaveCommand}" IsEnabled="{Binding IsNotBusy}" FontSize="16" FontAttributes="Bold" HeightRequest="52" CornerRadius="14" TextColor="White" Margin="0,4,0,0">
                <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#0891B2" Offset="0.0" />
                        <GradientStop Color="#06B6D4" Offset="1.0" />
                    </LinearGradientBrush>
                </Button.Background>
                <Button.Shadow><Shadow Brush="#0891B2" Offset="0,4" Radius="12" Opacity="0.35" /></Button.Shadow>
            </Button>

            <!-- Delete Button (only in edit mode) -->
            <Button Text="Excluir Reservatório" Command="{Binding DeleteCommand}" IsVisible="{Binding IsEditing}" IsEnabled="{Binding IsNotBusy}" FontSize="14" HeightRequest="46" CornerRadius="14" TextColor="#EF4444" BackgroundColor="#FEE2E2" BorderColor="#FECACA" BorderWidth="1" />

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" Color="{StaticResource AquaPrimary}" HorizontalOptions="Center" />

            <!-- Status Message -->
            <Border IsVisible="{Binding HasStatus}" StrokeShape="RoundRectangle 12" Stroke="Transparent" Padding="16,12" Margin="0,0,0,10">
                <Border.Triggers>
                    <DataTrigger TargetType="Border" Binding="{Binding IsSuccess}" Value="True"><Setter Property="BackgroundColor" Value="#D1FAE5" /></DataTrigger>
                    <DataTrigger TargetType="Border" Binding="{Binding IsSuccess}" Value="False"><Setter Property="BackgroundColor" Value="#FEE2E2" /></DataTrigger>
                </Border.Triggers>
                <Label Text="{Binding StatusMessage}" FontSize="13" HorizontalTextAlignment="Center" HorizontalOptions="Center">
                    <Label.Triggers>
                        <DataTrigger TargetType="Label" Binding="{Binding IsSuccess}" Value="True"><Setter Property="TextColor" Value="#10B981" /></DataTrigger>
                        <DataTrigger TargetType="Label" Binding="{Binding IsSuccess}" Value="False"><Setter Property="TextColor" Value="#EF4444" /></DataTrigger>
                    </Label.Triggers>
                </Label>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
